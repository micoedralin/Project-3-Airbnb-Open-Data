-- What neighborhoods have the highest nightly prices for private rooms in New York City? --

SELECT
    neighborhood,
    borough,
    room_type,
    COUNT(*) AS listing_count,
    ROUND(AVG(price), 2) AS avg_price_per_night,
    PERCENTILE_CONT(.5) WITHIN GROUP (ORDER BY price) AS median_price_per_night
FROM 
    airbnb_data
WHERE
    price IS NOT NULL
    AND price BETWEEN 50 AND 1500
    AND room_type = 'Private room'
    AND minimum_nights = 1
GROUP BY
    borough,
    neighborhood,
    room_type
HAVING
    COUNT(*) >= 50
ORDER BY
    median_price_per_night DESC;


